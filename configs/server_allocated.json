{
  "log": { "loglevel": "warning" },

  "ratelimit": {
    "graceSeconds": 300
  },

  "api": {
    "tag": "api",
    "listen": "0.0.0.0:10085",
    "services": [
      "reflectionservice",
      "handlerservice",
      "ratelimitservice"
    ]
  },

  "inbounds": [
    {
      "tag": "reality-vless-microsoft",
      "listen": "0.0.0.0",
      "port": 10443,
      "protocol": "vless",

      "settings": {
        "clients": [],
        "decryption": "none",
        "fallbacks": [
          {
            "name": "www.microsoft.com",
            "dest": 11443
          }
        ]
      },

      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.microsoft.com:443",
          "xver": 0,
          "serverNames": ["www.microsoft.com"],
          "privateKey": "sLX9ZWx6wEYAVOIHxXzBdChymbLNgJ68bP0BbIUS4lU",
          "shortIds": ["23f7178936edc8c6"]
        }
      },

      "sniffing": {
        "enabled": false,
        "destOverride": ["http", "tls", "quic"],
        "metadataOnly": false,
        "routeOnly": false
      }
    },

    {
      "tag": "reality-vless-yandex",
      "listen": "0.0.0.0",
      "port": 20443,
      "protocol": "vless",

      "settings": {
        "clients": [],
        "decryption": "none",
        "fallbacks": [
          {
            "name": "browser.yandex.ru",
            "dest": 21443
          }
        ]
      },

      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "browser.yandex.ru:443",
          "xver": 0,
          "serverNames": ["browser.yandex.ru"],
          "privateKey": "sLX9ZWx6wEYAVOIHxXzBdChymbLNgJ68bP0BbIUS4lU",
          "shortIds": ["23f7178936edc8c6"]
        }
      },

      "sniffing": {
        "enabled": false,
        "destOverride": ["http", "tls", "quic"],
        "metadataOnly": false,
        "routeOnly": false
      }
    },

    {
      "tag": "reality-vless-x5",
      "listen": "0.0.0.0",
      "port": 30443,
      "protocol": "vless",

      "settings": {
        "clients": [],
        "decryption": "none",
        "fallbacks": [
          {
            "name": "5post-gate.x5.ru",
            "dest": 31443
          }
        ]
      },

      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "5post-gate.x5.ru:443",
          "xver": 0,
          "serverNames": ["5post-gate.x5.ru"],
          "privateKey": "sLX9ZWx6wEYAVOIHxXzBdChymbLNgJ68bP0BbIUS4lU",
          "shortIds": ["23f7178936edc8c6"]
        }
      },

      "sniffing": {
        "enabled": false,
        "destOverride": ["http", "tls", "quic"],
        "metadataOnly": false,
        "routeOnly": false
      }
    },

    {
      "tag": "xhttp-vless-microsoft",
      "listen": "127.0.0.1",
      "port": 11443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "host": "www.microsoft.com",
          "path": "/xhttp",
          "mode": "auto"
        }
      },
      "sniffing": {
        "enabled": false
      }
    },

    {
      "tag": "xhttp-vless-yandex",
      "listen": "127.0.0.1",
      "port": 21443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "host": "browser.yandex.ru",
          "path": "/xhttp",
          "mode": "auto"
        }
      },
      "sniffing": {
        "enabled": false
      }
    },

    {
      "tag": "xhttp-vless-x5",
      "listen": "127.0.0.1",
      "port": 31443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "host": "5post-gate.x5.ru",
          "path": "/xhttp",
          "mode": "auto"
        }
      },
      "sniffing": {
        "enabled": false
      }
    },

    {
      "tag": "health-socks",
      "listen": "127.0.0.1",
      "port": 1081,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": false
      }
    }
  ],

  "outbounds": [
    { "tag": "direct", "protocol": "freedom" },
    { "tag": "block", "protocol": "blackhole" }
  ],

  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "public",
        "inboundTag": [
          "reality-vless-microsoft",
          "reality-vless-yandex",
          "reality-vless-x5",
          "xhttp-vless-microsoft",
          "xhttp-vless-yandex",
          "xhttp-vless-x5"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "health-check",
        "inboundTag": ["health-socks"],
        "outboundTag": "direct"
      }
    ]
  }
}
