      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      }
    },
    {
      "tag": "reality-vless",
      "listen": "0.0.0.0",
      "port": 1443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "browser.yandex.ru:443",
          "serverNames": [
            "browser.yandex.ru"
          ],
          "privateKey": "sLX9ZWx6wEYAVOIHxXzBdChymbLNgJ68bP0BbIUS4lU",
          "shortIds": [
            "23f7178936edc8c6"
          ]
        },
        "xhttpSettings": {
          "host": "browser.yandex.ru",
          "path": "/xhttp",
          "mode": "auto"
        }
      },
      "sniffing": {
        "enabled": false
      }
    },
{
      "tag": "reality-vless-2443",
      "listen": "0.0.0.0",
      "port": 2443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "browser.yandex.ru:443",
          "serverNames": [
            "browser.yandex.ru"
          ],
          "privateKey": "sLX9ZWx6wEYAVOIHxXzBdChymbLNgJ68bP0BbIUS4lU",
          "shortIds": [
            "23f7178936edc8c6"
          ]
        },
        "xhttpSettings": {
          "host": "browser.yandex.ru",
          "path": "/xhttp",
          "mode": "auto"
        }
      },
      "sniffing": {
        "enabled": false
