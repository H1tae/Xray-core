{
  "log": {
    "loglevel": "info"
  },

  "ratelimit":{
    "grace": 300
  },
  
  "api": {
    "tag": "api",
    "services": ["HandlerService", "StatsService", "RateLimitService"]
  },

  "inbounds": [
    {
      "tag": "api-in",
      "listen": "127.0.0.1",
